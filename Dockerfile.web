# Sweet Apocalypse Comic Factory - Web UI Dockerfile
FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    wget \
    curl \
    unzip \
    libgl1-mesa-glx \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application files
COPY . .

# Create necessary directories
RUN mkdir -p uploads models output rag_documents static

# Download base models (placeholder - would download actual models)
RUN echo "Downloading base models..." && \
    mkdir -p models/text models/image models/loras

# Expose port
EXPOSE 8080

# Set environment variables
ENV PYTHONPATH=/app
ENV OLLAMA_URL=http://localhost:11434
ENV COMFYUI_URL=http://localhost:8188

# Health check
HEALTHCHECK --interval=30s --timeout=30s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8080/api/status || exit 1

# Run the application
CMD ["python", "server.py"]
